{
  "manifest_version": 3,
  "name": "Claude Peak Monitor",
  "version": "1.4",
  "description": "Alerte heures de pointe",
  "author": "Lesjeuxmathis",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/chat/*", "https://claude.ai/new"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": ["https://claude.ai/*"]
}
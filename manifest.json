{
  "manifest_version": 3,
  "name": "Claude Peak Monitor",
  "version": "3.0",
  "description": "Outil communautaire (non officiel) — alerte en temps réel lors des heures de pointe de Claude.ai",
  "author": "Lesjeuxmathis",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["alarms"],
  "host_permissions": ["https://claude.ai/*"]
}
